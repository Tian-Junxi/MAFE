<launch>
  <!-- 输入 IMU CSV 路径。CSV 默认 6 列：gyro_x,gyro_y,gyro_z,acc_x,acc_y,acc_z -->
  <arg name="csv_path" default="$(find imu_spectrum_gaussian_fit)/examples/example_imu_200hz_6cols.csv" />

  <!-- 输出目录：保存谱峰参数 CSV、频谱拟合 CSV、SVG 图 -->
  <arg name="output_dir" default="/tmp/imu_spectrum_gaussian_fit" />

  <!-- 参数文件 -->
  <arg name="param_file" default="$(find imu_spectrum_gaussian_fit)/config/fit_params.yaml" />

  <node pkg="imu_spectrum_gaussian_fit"
        type="imu_gaussian_fit_node"
        name="imu_gaussian_fit_node"
        output="screen">
    <rosparam command="load" file="$(arg param_file)" />
    <param name="csv_path" value="$(arg csv_path)" />
    <param name="output_dir" value="$(arg output_dir)" />
  </node>
</launch>
